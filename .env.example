# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_MAX_TOKENS=32768
LLM_MAX_RETRIES=2
LLM_RETRY_DELAY_MS=1500
LLM_RETRY_BACKOFF_MULTIPLIER=2
AGENT_FALLBACK_MAX_RETRIES=1
UX_AGENT_MAX_RETRIES=2
UX_AGENT_FALLBACK_MODEL=anthropic/claude-sonnet-4.6
UX_AGENT_ALLOW_DEGRADED=true
GENERATED_FILE_BATCH_SIZE=4
MAX_CODE_REVIEW_FIX_ITERATIONS=2
MAX_DEPLOY_FIX_ITERATIONS=2
MAX_BUILD_READINESS_FIX_ITERATIONS=2
MAX_EXECUTION_VALIDATION_FIX_ITERATIONS=3
MAX_QA_FIX_ITERATIONS=1
MAX_REPAIR_LOG_CHARS=8000
MAX_REPAIR_TOTAL_LOG_CHARS=20000
MAX_REPAIR_TREE_FILES=120
RUN_COST_WARN_USD=4
RUN_COST_BUDGET_USD=6

ENABLE_DASHBOARD=false
DASHBOARD_OPTIONAL=true
DASHBOARD_REQUIRED=false
DASHBOARD_AUTO_REGISTER=false

OPENROUTER_APP_NAME=Agentic Sprint Builder
OPENROUTER_SITE_URL=http://localhost:3000

# Contest dashboard
DASHBOARD_BASE_URL=https://aitechcontest.kms-technology.com/api
DASHBOARD_COMPANY_ID=
DASHBOARD_AGENT_IDS=
DASHBOARD_AGENT_BA_ID=
DASHBOARD_AGENT_TECH_STACK_ID=
DASHBOARD_AGENT_UX_ID=
DASHBOARD_AGENT_DEV_ID=
DASHBOARD_AGENT_FRONTEND_DEV_ID=
DASHBOARD_AGENT_BACKEND_DEV_ID=
DASHBOARD_AGENT_INTEGRATION_DEV_ID=
DASHBOARD_AGENT_CODE_REVIEW_ID=
DASHBOARD_AGENT_DEPLOY_ID=
DASHBOARD_AGENT_QA_ID=
# Optional override. Supports {company_id}; default tries /companies/{company_id}/agents then /agents.
DASHBOARD_AGENT_CREATE_PATH=
# Optional override. Supports {company_id}, {agent_id}, {logical_agent_id}; default tries /companies/{company_id}/agents/{agent_id} then /agents/{agent_id}.
DASHBOARD_AGENT_DELETE_PATH=
# Optional override. Supports {company_id}, {agent_id}, {to_agent_id}; default tries /events and company/agent scoped event paths.
DASHBOARD_EVENT_PATH=
DASHBOARD_REQUIRE_AGENT_IDS=false
DASHBOARD_COMPANY_NAME=Thermo Mini
DASHBOARD_CONNECTIVITY_TIMEOUT_MS=8000
VALIDATE_GENERATED_EXECUTION=true
VALIDATE_GENERATED_BROWSER=true
GENERATED_BROWSER_EXECUTABLE_PATH=
GENERATED_BROWSER_VIRTUAL_TIME_BUDGET_MS=8000
ALLOW_GENERATED_DOCKER=true
FALLBACK_LOCAL_VALIDATION_WHEN_COMPOSE_SKIPPED=true
AUTO_RUN_GENERATED_APP=true
GENERATED_BACKEND_PORT=8000
GENERATED_FRONTEND_PORT=3001
GENERATED_COMPOSE_ENGINE=auto
AUTO_START_RANCHER_DESKTOP=true
RANCHER_DESKTOP_PATH=
RANCHER_RDCTL_PATH=
RANCHER_START_CONTAINER_ENGINE=moby
RANCHER_START_KUBERNETES=false
RANCHER_START_IN_BACKGROUND=true
RANCHER_START_TIMEOUT_MS=600000
RANCHER_READY_POLL_MS=3000
CLEAN_GENERATED_COMPOSE=true
REMOVE_GENERATED_COMPOSE_VOLUMES=true
REMOVE_GENERATED_COMPOSE_IMAGES=false
MEDIA_ASSET_LIMIT=4
MEDIA_ASSET_DOWNLOAD_TIMEOUT_MS=12000
RUN_FULL_QA_AGENT=auto
RUN_STATUS_RATE_LIMIT_MAX=300
RUN_RATE_LIMIT_MAX=60
RUN_STATUS_RATE_LIMIT_WINDOW_MS=60000
