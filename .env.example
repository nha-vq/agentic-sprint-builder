# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o-mini

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# Local safety defaults
ENABLE_DASHBOARD=false
RUN_RATE_LIMIT_MAX=10
RUN_RATE_LIMIT_WINDOW_MS=600000
# In production, set RUN_API_TOKEN or explicitly set ALLOW_UNAUTHENTICATED_RUNS=true.
RUN_API_TOKEN=
ALLOW_UNAUTHENTICATED_RUNS=false

OPENROUTER_APP_NAME=Agentic Sprint Builder
OPENROUTER_SITE_URL=http://localhost:3000

# Contest dashboard
DASHBOARD_BASE_URL=https://aitechcontest.kms-technology.com/api
DASHBOARD_COMPANY_ID=
DASHBOARD_COMPANY_NAME=Agentic Sprint Builder
